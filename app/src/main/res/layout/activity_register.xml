<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:id="@+id/main"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="224dp"
            android:scaleType="fitCenter"
            android:src="@drawable/register_top_image" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Let's complete your profile"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginTop="24dp"
            android:layout_gravity="center_horizontal"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="It will help us to know more about you!"
            android:textSize="16sp"
            android:textColor="#888888"
            android:layout_marginTop="8dp"
            android:layout_gravity="center_horizontal"/>

        <Spinner
            android:id="@+id/gender_spinner"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/edittext_bg"
            android:paddingStart="12dp"
            android:layout_marginTop="24dp"
            android:entries="@array/gender_array" />

        <EditText
            android:id="@+id/date_of_birth_edit_text"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="  Date of Birth"
            android:inputType="none"
            android:drawableStart="@drawable/ic_calendar"
            android:background="@drawable/edittext_bg"
            android:paddingStart="12dp"
            android:layout_marginTop="12dp"
            android:focusable="false"
            android:clickable="true"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">
            <EditText
                android:id="@+id/weight_edit_text"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:hint="  Your Weight"
                android:inputType="numberDecimal"
                android:drawableStart="@drawable/ic_weightscale"
                android:background="@drawable/edittext_bg"
                android:paddingStart="12dp"
                android:layout_marginEnd="8dp"
                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/gradient_button"
                android:padding="10dp"
                android:text="KG"
                android:textColor="#ffff"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">
            <EditText
                android:id="@+id/height_edit_text"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:hint="  Your Height"
                android:inputType="numberDecimal"
                android:drawableStart="@drawable/ic_swap"
                android:background="@drawable/edittext_bg"
                android:paddingStart="12dp"
                android:layout_marginEnd="8dp"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/gradient_button"
                android:text="CM"
                android:textSize="16sp"
                android:textColor="#ffffff"
                android:padding="10dp"/>
        </LinearLayout>

        <Button
            android:id="@+id/next_button"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/gradient_button"
            android:text="Next   >"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>