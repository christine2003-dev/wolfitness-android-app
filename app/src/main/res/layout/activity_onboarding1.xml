<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    android:background="#FFFFFF"
    >

    <ImageView
        android:id="@+id/onboarding1_image"
        android:layout_width="500dp"
        android:layout_height="480dp"
        android:src="@drawable/onboarding1_image"
        app:layout_constraintHeight_percent="0.5"
        app:layout_constraintHorizontal_bias="0.382"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/text_track_goal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
         android:gravity="center"
        android:text="Track Your Goal"
        android:textColor="#000000"
        android:textSize="36sp"
        android:textStyle="bold"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/onboarding1_image"

        />

    <TextView
        android:id="@+id/text_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily=" " android:gravity="left"
        android:text="Don’t worry if you have trouble determining your goals. We can help you determine your goals and track them."
        android:textColor="#666666"
        android:textSize="16sp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/text_track_goal"
        android:padding="24dp"/>

    <ImageView
        android:id="@+id/btn_next_onboarding1"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/ic_arrow_right"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintRight_toRightOf="parent"
     android:layout_margin="15dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>